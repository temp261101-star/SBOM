<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.example.model">
    
    <class name="emp" table="emp">
        
        <id name="id" column="EMP_ID" type="long">
            <generator class="identity"/>
        </id>
        
        <property name="emp_name" column="emp_name" 
                  type="string" length="50" not-null="true"/>
        
        <property name="email_address" column="EMAIL_ADDRESS" 
                  type="string" unique="true"/>

 <property name="emp_salary" column="emp_salary" type="Integer"/>

        <property name="emp_address" column="emp_address" type="varchar"/>

        <property name="emp_contact" column="emp_contact" type="varchar"/>

        
    </class>
    
</hibernate-mapping>